# Copy this file to ".env" and fill in your own EmailJS values to let the
# contact form send email straight from the browser (no backend needed).
# Get these three values from https://dashboard.emailjs.com after creating a
# free account, an Email Service, and an Email Template.
# See README.md → "Connect the contact form to your email" for the full walkthrough.
#
# Until these are filled in, the contact form still works — it falls back to
# opening a pre-filled mailto: link instead.

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
